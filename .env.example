APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:Xf46iW/RmlU/5mnw7fWpSAo+1/5oCXOBX7tJkF1ohHk=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

# Database Config
DB_CONNECTION=mysql
# If using MySQL, uncomment below and add your details
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=fabric_db
